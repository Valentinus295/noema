#!/usr/bin/env bash
# ═══════════════════════════════════════════════════════════════
# Noema — One-Command Setup
# ═══════════════════════════════════════════════════════════════
#
# Local:      ./noema-setup
# Remote:     curl -fsSL https://raw.githubusercontent.com/Valentinus295/noema/main/noema-setup | bash
#
# This ONE command does everything:
#   • Clones the repo (if run remotely)
#   • Detects your OS (Linux/Windows/macOS)
#   • Installs all dependencies (Python, Rust, Node, Wine)
#   • Interactive credential prompts (stored in .env, chmod 600)
#   • Docker services (PostgreSQL + Redis)
#   • Builds Rust crates + dashboard
#
# After running, you'll have a fully operational Noema installation.
# ═══════════════════════════════════════════════════════════════

set -euo pipefail

# ── Parse flags ────────────────────────────────────────────────
NO_LAUNCH=false
for arg in "$@"; do
    case "$arg" in
        --no-launch) NO_LAUNCH=true ;;
    esac
done

# ── Bootstrap: detect if piped from curl ──────────────────────
if [[ ! -f "noema-setup" ]] && [[ -t 0 ]]; then
    # Running from a local clone — use current directory
    SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    cd "$SCRIPT_DIR"
elif [[ ! -f "noema-setup" ]]; then
    # Piped from curl — clone the repo
    echo ""
    echo "  🧠  Noema — cloning repository..."
    echo ""
    NOEMA_DIR="$HOME/noema"
    if [ -d "$NOEMA_DIR" ]; then
        echo "  → Noema already exists at $NOEMA_DIR"
        cd "$NOEMA_DIR"
        git pull --ff-only 2>/dev/null || true
    else
        git clone https://github.com/Valentinus295/noema.git "$NOEMA_DIR"
        cd "$NOEMA_DIR"
    fi
    SCRIPT_DIR="$NOEMA_DIR"
else
    # Running locally
    SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    cd "$SCRIPT_DIR"
fi

# ── Self-repair: fix pyproject.toml if [project.urls] before deps ──
if [ -f pyproject.toml ] && grep -q "^\[project\.urls\]" pyproject.toml; then
    if awk '/\[project\.urls\]/{found=1} /^dependencies =/{if(found){print "broken"; exit}}' pyproject.toml | grep -q broken; then
        echo ""
        echo -e "  ${YELLOW}Repairing pyproject.toml structure...${NC}"
        python3 -c "
content = open('pyproject.toml').read()
lines = content.split('\n')
new, urls_block, in_urls = [], [], False
for line in lines:
    if line.startswith('[project.urls]'):
        in_urls = True
        urls_block.append(line)
    elif in_urls:
        if line.startswith('[') or (line.strip() and not line.startswith('Homepage') and not line.startswith('Repository') and not line.startswith('Documentation') and not line.startswith('Issues')):
            in_urls = False
        else:
            urls_block.append(line)
            continue
    if not in_urls:
        new.append(line)
# Insert urls before [build-system]
final = '\n'.join(new)
urls_text = '\n'.join(urls_block)
final = final.replace('\n[build-system]', f'\n{urls_text}\n[build-system]')
open('pyproject.toml','w').write(final)
print('OK')
" 2>/dev/null && echo -e "  ${GREEN}✓${NC} pyproject.toml fixed" || echo -e "  ${RED}✗${NC} Could not auto-fix"
    fi
fi

# ── Colors ───────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

banner() {
    echo -e "${CYAN}${BOLD}"
    echo "╔═══════════════════════════════════════════╗"
    echo "║   🧠  Noema — Production Setup            ║"
    echo "║   Multi-Agent Quantitative Forex Trading  ║"
    echo "╚═══════════════════════════════════════════╝"
    echo -e "${NC}"
}

section() {
    echo ""
    echo -e "${BLUE}${BOLD}━━━ $1 ━━━${NC}"
    echo ""
}

success() { echo -e "  ${GREEN}✓${NC} $1"; }
warn()    { echo -e "  ${YELLOW}⚠${NC} $1"; }
fail()    { echo -e "  ${RED}✗${NC} $1"; }
info()    { echo -e "  ${CYAN}→${NC} $1"; }

prompt_secret() {
    # prompt_secret "Label" "ENV_VAR_NAME" "default_value" "help_text"
    local label="$1" var="$2" default="$3" help="$4"
    local value
    echo ""
    echo -e "  ${BOLD}${label}${NC}"
    if [ -n "$help" ]; then
        echo -e "  ${CYAN}${help}${NC}"
    fi
    read -r -s -p "  Enter value [hidden]: " value < /dev/tty
    echo ""
    value="${value:-$default}"
    echo "${var}=${value}" >> .env
    success "${var} configured"
}

prompt_choice() {
    # prompt_choice "Label" "ENV_VAR_NAME" "default" "options" "help"
    local label="$1" var="$2" default="$3" options="$4" help="$5"
    local value
    echo ""
    echo -e "  ${BOLD}${label}${NC}"
    if [ -n "$help" ]; then echo -e "  ${CYAN}${help}${NC}"; fi
    echo -e "  Options: ${options}"
    read -r -p "  Enter value [${default}]: " value < /dev/tty
    value="${value:-$default}"
    echo "${var}=${value}" >> .env
    success "${var}=${value}"
}

# ═══════════════════════════════════════════════════════════════
# MAIN
# ═══════════════════════════════════════════════════════════════

banner

# Paths for Pop!_OS / Ubuntu
# Auto-detect MT5 path — search common Wine locations
WINE_MT5_PATH=""
for candidate in \
    "$HOME/.wine/drive_c/Program Files/MetaTrader 5/terminal64.exe" \
    "$HOME/.wine/drive_c/Program Files (x86)/MetaTrader 5/terminal64.exe" \
    "$HOME/.wine/drive_c/FxPesa/terminal64.exe" \
    "$HOME/.wine/drive_c/FBS/terminal64.exe"; do
    if [ -f "$candidate" ]; then
        WINE_MT5_PATH="$candidate"
        break
    fi
done
if [ -z "$WINE_MT5_PATH" ]; then
    WINE_MT5_PATH="$HOME/.wine/drive_c/Program Files/MetaTrader 5/terminal64.exe"
fi

# ── Step 0: Prerequisites Check ───────────────────────────────
section "Step 0: Checking prerequisites"

OS="$(uname -s)"
echo -e "  ${BOLD}System:${NC} $(uname -s) $(uname -m)"
PYTHON_VER=$(python3 --version 2>&1 | grep -oP '\d+\.\d+' | head -1)
echo -e "  ${BOLD}Python:${NC} $(python3 --version 2>&1)"
if [ -n "$PYTHON_VER" ] && [ "$(echo "$PYTHON_VER >= 3.11" | bc -l 2>/dev/null || echo 0)" = "1" ] 2>/dev/null; then
    success "Python version $PYTHON_VER >= 3.11 — OK"
elif python3 -c "import sys; sys.exit(0 if sys.version_info >= (3,11) else 1)" 2>/dev/null; then
    success "Python version >= 3.11 — OK"
else
    fail "Python 3.11+ REQUIRED — found $(python3 --version 2>&1)"
    echo -e "  ${YELLOW}Install Python 3.11+:${NC}"
    if [ "$OS" = "Linux" ]; then
        echo -e "  Ubuntu 22.04: sudo add-apt-repository ppa:deadsnakes/ppa && sudo apt install python3.11 python3.11-venv"
        echo -e "  Ubuntu 24.04+: sudo apt install python3.11 python3.11-venv"
    elif [ "$OS" = "Darwin" ]; then
        echo -e "  brew install python@3.12"
        echo -e "  OR download from: https://www.python.org/downloads/"
    elif echo "$OS" | grep -qE "MINGW|MSYS|CYGWIN"; then
        echo -e "  Download from: https://www.python.org/downloads/"
        echo -e "  OR from Microsoft Store: search 'Python 3.12'"
        echo -e "  ${YELLOW}⚠️  Check 'Add Python to PATH' during installation!${NC}"
    else
        echo -e "  Download from: https://www.python.org/downloads/"
    fi
    exit 1
fi
echo ""
if [ "$OS" = "Linux" ]; then
    echo -e "  ${GREEN}✓${NC} Linux — Wine + mt5linux for MT5"
    NEED_WINE=true
elif echo "$OS" | grep -qE "MINGW|MSYS|CYGWIN"; then
    echo -e "  ${GREEN}✓${NC} Windows — native MT5"
    NEED_WINE=false
elif [ "$OS" = "Darwin" ]; then
    echo -e "  ${YELLOW}⚠${NC}  macOS — paper trading only"
    NEED_WINE=false
else
    echo -e "  ${YELLOW}⚠${NC}  Unknown OS — paper trading"
    NEED_WINE=false
fi
echo ""
MISSING=()

check_cmd() {
    if command -v "$1" &> /dev/null; then
        success "$1 ($($1 --version 2>&1 | head -1))"
    else
        fail "$1 — NOT FOUND"
        MISSING+=("$1")
    fi
}

check_cmd python3
# Check for xvfb (needed for headless MT5 on Linux)
if [ "$NEED_WINE" = "true" ]; then
    if command -v xvfb-run &> /dev/null; then
        success "xvfb-run (headless MT5 support)"
    else
        warn "xvfb-run — NOT FOUND"
        MISSING+=("xvfb-run")
    fi
fi
# Only require Wine on Linux
if [ "$NEED_WINE" = "true" ]; then
    if command -v wine &> /dev/null; then
        success "wine ($(wine --version 2>&1))"
    else
        warn "wine — NOT FOUND (needed for MT5 on Linux)"
        MISSING+=("wine")
    fi
fi
check_cmd pip3 2>/dev/null || check_cmd uv

# ── Cross-platform venv activation helper ──
# On macOS/Linux:  .venv/bin/activate
# On Windows Git Bash: .venv/Scripts/activate
activate_venv() {
    if [ -f ".venv/bin/activate" ]; then
        source .venv/bin/activate 2>/dev/null || true
    elif [ -f ".venv/Scripts/activate" ]; then
        source .venv/Scripts/activate 2>/dev/null || true
    fi
}

# ── Detect WSL (Windows Subsystem for Linux) ──
IS_WSL=false
if [ "$OS" = "Linux" ] && grep -qi microsoft /proc/version 2>/dev/null; then
    IS_WSL=true
    echo -e "  ${CYAN}→${NC} WSL detected — using Linux package management"
fi

# ── Step 0.5: System dependencies (CRITICAL for builds) ────────
section "Step 0.5: System build dependencies"

if [ "$OS" = "Linux" ]; then
    # ═══════════════════════════════════════════════════════════
    # LINUX (Ubuntu / Pop!_OS / Debian / WSL)
    # ═══════════════════════════════════════════════════════════

    # Update package list once (shared across all installs)
    sudo apt-get update -qq 2>/dev/null

    # Install build tools and libraries
    # NOTE: libta-lib-dev is NOT in standard apt repos — built from source below
    info "Installing build tools and libraries..."
    sudo apt-get install -y -qq build-essential cmake pkg-config python3-venv \
        libssl-dev libffi-dev wget curl 2>&1 | tail -3

    if command -v cmake &> /dev/null; then
        success "Build tools installed (gcc, cmake, pkg-config)"
    fi

    # ═══════════════════════════════════════════════════════════
    # TA-Lib: Build from source (NOT available in standard apt repos)
    # Idempotent — skips if already installed
    # ═══════════════════════════════════════════════════════════
    if ldconfig -p 2>/dev/null | grep -q libta_lib; then
        success "TA-Lib C library already installed (skipping build)"
    else
        info "Building TA-Lib from source (not in apt repos)..."
        # Refresh sudo timestamp so make install doesn't silently fail
        sudo -v 2>/dev/null || true
        TA_BUILD_DIR=$(mktemp -d)
        (
            cd "$TA_BUILD_DIR"
            wget -q http://prdownloads.sourceforge.net/ta-lib/ta-lib-0.4.0-src.tar.gz || {
                wget -q https://github.com/TA-Lib/ta-lib/releases/download/v0.4.0/ta-lib-0.4.0-src.tar.gz || {
                    echo "TA-Lib download failed"
                    exit 1
                }
            }
            tar xzf ta-lib-0.4.0-src.tar.gz
            cd ta-lib/
            ./configure --prefix=/usr > /dev/null 2>&1
            make -j"$(nproc)" > /dev/null 2>&1
            sudo make install > /dev/null 2>&1 || { echo "TA-Lib install failed"; exit 1; }
            sudo ldconfig > /dev/null 2>&1
        )
        rm -rf "$TA_BUILD_DIR"

        # Verify: check both ldconfig cache AND file existence
        if ldconfig -p 2>/dev/null | grep -q libta_lib; then
            success "TA-Lib C library built and installed"
        elif [ -f /usr/lib/libta_lib.so ] || [ -f /usr/local/lib/libta_lib.so ] || ls /usr/lib/libta_lib* >/dev/null 2>&1; then
            success "TA-Lib C library built (found on disk)"
        else
            warn "TA-Lib C library build may have failed — pip TA-Lib will fail if missing"
            info "Manual fix: https://github.com/TA-Lib/ta-lib#build-from-source"
        fi
    fi

elif [ "$OS" = "Darwin" ]; then
    # ═══════════════════════════════════════════════════════════
    # macOS
    # ═══════════════════════════════════════════════════════════

    # ── Homebrew check ──
    if ! command -v brew &> /dev/null; then
        fail "Homebrew not found — REQUIRED for macOS dependency management"
        echo ""
        echo -e "  ${YELLOW}Install Homebrew (one command):${NC}"
        echo -e "  ${CYAN}/bin/bash -c \"\$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)\"${NC}"
        echo -e "  ${YELLOW}After installing Homebrew, re-run this script.${NC}"
        echo ""
        exit 1
    fi
    success "Homebrew found"

    # ── Xcode CLI tools ──
    if xcode-select -p &> /dev/null; then
        success "Xcode CLI tools installed"
    else
        warn "Xcode CLI tools not found — installing now..."
        info "This may open a GUI dialog — click 'Install' and wait for completion"
        xcode-select --install 2>/dev/null || true
        echo -e "  ${YELLOW}After Xcode CLI tools finish installing, re-run this script.${NC}"
        exit 1
    fi

    # ── Build tools via Homebrew ──
    # macOS ships with clang/gcc via Xcode — no build-essential needed
    info "Checking build dependencies..."
    BREW_DEPS=()
    command -v cmake &> /dev/null || BREW_DEPS+=(cmake)
    command -v pkg-config &> /dev/null || BREW_DEPS+=(pkg-config)
    command -v wget &> /dev/null || BREW_DEPS+=(wget)

    if [ ${#BREW_DEPS[@]} -gt 0 ]; then
        info "Installing via Homebrew: ${BREW_DEPS[*]}"
        brew install "${BREW_DEPS[@]}" 2>&1 | tail -5
        success "Build tools installed via Homebrew"
    else
        success "Build tools already present"
    fi

    # ── TA-Lib via Homebrew ──
    if [ -f /opt/homebrew/lib/libta_lib.dylib ] || [ -f /usr/local/lib/libta_lib.dylib ] || [ -f /opt/homebrew/opt/ta-lib/lib/libta_lib.dylib ]; then
        success "TA-Lib C library already installed (skipping)"
    else
        info "Installing TA-Lib via Homebrew..."
        if brew install ta-lib 2>&1 | tail -5; then
            success "TA-Lib installed via Homebrew"
        else
            warn "TA-Lib Homebrew install failed"
            info "Manual fix: brew install ta-lib"
            info "Fallback: build from source — https://github.com/TA-Lib/ta-lib#build-from-source"
        fi
    fi

elif echo "$OS" | grep -qE "MINGW|MSYS|CYGWIN"; then
    # ═══════════════════════════════════════════════════════════
    # WINDOWS (Git Bash / MSYS2 / Cygwin)
    # ═══════════════════════════════════════════════════════════

    info "Windows detected (Git Bash / MSYS2 environment)"
    info "Skipping apt-based system deps — Windows uses pre-built wheels and native installers"

    # ── Python check ──
    PYTHON_CMD=""
    if command -v python3 &> /dev/null; then
        PYTHON_CMD="python3"
        success "python3 found: $(python3 --version 2>&1)"
    elif command -v python &> /dev/null; then
        PYTHON_CMD="python"
        success "python found: $(python --version 2>&1)"
    else
        fail "Python not found in PATH"
        echo ""
        echo -e "  ${YELLOW}Install Python 3.11+ from:${NC}"
        echo -e "  ${CYAN}https://www.python.org/downloads/${NC}"
        echo -e "  ${YELLOW}OR from Microsoft Store: search 'Python 3.12'${NC}"
        echo -e "  ${YELLOW}⚠️  IMPORTANT: Check 'Add Python to PATH' during installation!${NC}"
        echo ""
        exit 1
    fi

    # ── Cargo/Rust check ──
    if command -v cargo &> /dev/null; then
        success "cargo found: $(cargo --version 2>&1)"
    else
        warn "cargo not found — Rust crates will use Python fallbacks"
        info "Install from: https://rustup.rs"
    fi

    # ── TA-Lib via pip wheel (Christoph Gohlke pre-built binaries on PyPI for Windows) ──
    # Windows TA-Lib binaries available directly on PyPI — no C source build needed
    if python3 -c "import talib" 2>/dev/null; then
        success "TA-Lib Python package already installed"
    else
        info "Installing TA-Lib via pip (pre-built Windows wheel from PyPI)..."
        if pip install TA-Lib 2>&1 | tail -3; then
            success "TA-Lib installed from PyPI wheel"
        else
            warn "TA-Lib pip install failed — trying with --only-binary"
            if pip install --only-binary :all: TA-Lib 2>&1 | tail -3; then
                success "TA-Lib installed (binary wheel)"
            else
                warn "TA-Lib could not be installed from PyPI"
                info "Manual fix: download wheel from https://www.lfd.uci.edu/~gohlke/pythonlibs/#ta-lib"
                info "Then: pip install TA_Lib-0.6.7-cp311-cp311-win_amd64.whl (match your Python version)"
            fi
        fi
    fi

else
    # ═══════════════════════════════════════════════════════════
    # Unknown / Other OS
    # ═══════════════════════════════════════════════════════════
    warn "Unrecognized OS: $OS — skipping system dependencies"
    info "You may need to install manually:"
    info "  • C compiler (gcc/clang)"
    info "  • cmake + pkg-config"
    info "  • TA-Lib C library: https://github.com/TA-Lib/ta-lib"
fi
check_cmd cargo 2>/dev/null || true  # Rust optional at first
check_cmd node   2>/dev/null || true  # Node optional at first

if [ ${#MISSING[@]} -gt 0 ]; then
    echo ""
    echo -e "${RED}${BOLD}Missing prerequisites:${NC}"
    for m in "${MISSING[@]}"; do
        case "$m" in
            python3)
                echo "  python3 →"
                if [ "$OS" = "Linux" ]; then
                    echo "             Ubuntu 22.04: ppa:deadsnakes/ppa + apt install python3.11"
                    echo "             Ubuntu 24.04: apt install python3.11"
                elif [ "$OS" = "Darwin" ]; then
                    echo "             brew install python@3.12"
                else
                    echo "             https://www.python.org/downloads/"
                fi
                ;;
            cargo)   echo "  cargo   → install from https://rustup.rs" ;;
            node)    echo "  node    → install from https://nodejs.org (LTS)" ;;
            xvfb-run) echo "  xvfb-run → 'sudo apt install xvfb' (headless MT5)" ;;
            wine)    echo "  wine    → 'sudo apt install wine64 wine32' (MT5 on Linux)" ;;
            *)       echo "  $m — please install manually" ;;
        esac
    done
    echo ""
    if [[ "${MISSING[*]}" =~ "xvfb-run" ]]; then
        echo -e "  ${CYAN}→ Auto-installing xvfb now...${NC}"
        (sudo apt-get update -qq && sudo apt-get install -y -qq xvfb) 2>/dev/null \
            && success "xvfb auto-installed" \
            || warn "xvfb auto-install failed — install manually: sudo apt install xvfb"
    fi
    if [[ "${MISSING[*]}" =~ "python3" ]]; then
        echo -e "${RED}Cannot continue without Python 3.11+. Install it first.${NC}"
        exit 1
    fi
    echo -e "${YELLOW}Continuing with available tools. Install missing ones later.${NC}"
fi

# ── Step 1: Wine + MT5 (platform-aware) ──────────────────────
section "Step 1: Platform-specific setup"

if [ "$NEED_WINE" = "true" ] && ! command -v wine &> /dev/null; then
    echo ""
    echo -e "  ${YELLOW}${BOLD}MT5 requires Wine on Linux.${NC}"
    echo -e "  ${CYAN}Pop!_OS 24.04 / Ubuntu — one command:${NC}"
    echo -e "  sudo dpkg --add-architecture i386"
    echo -e "  sudo apt update && sudo apt install wine64 wine32"
    echo ""
    echo -e "  ${CYAN}Then install MT5 from your broker:${NC}"
    echo -e "  wine ~/Downloads/fxpesa5setup.exe"
    echo ""
elif [ "$NEED_WINE" = "true" ] && [ -f "$WINE_MT5_PATH" ]; then
    success "Wine + MT5 detected"
    if command -v xvfb-run &> /dev/null; then
        success "xvfb-run available — headless MT5 supported"
    else
        warn "xvfb-run not found — headless MT5 NOT available"
    fi
elif [ "$NEED_WINE" = "true" ]; then
    success "Wine detected — install MT5: wine ~/Downloads/fxpesa5setup.exe"
elif [ "$NEED_WINE" = "false" ] && echo "$OS" | grep -qE "MINGW|MSYS|CYGWIN"; then
    success "Windows — native MT5 available (no Wine needed)"
    info "Download MT5 from your broker:"
    info "  • FxPesa: https://www.fxpesa.com/"
    info "  • FBS: https://fbs.com/"
    info "  • Or any MT5 broker of your choice"
elif [ "$OS" = "Darwin" ]; then
    warn "macOS — MT5 desktop app is Windows-only"
    echo ""
    echo -e "  ${YELLOW}Options for MT5 on macOS:${NC}"
    echo -e "    ${CYAN}•${NC} Paper trading — Noema's backtest and simulation modes work natively"
    echo -e "    ${CYAN}•${NC} CrossOver Mac — run MT5 without a VM (paid, https://www.codeweavers.com/)"
    echo -e "    ${CYAN}•${NC} Parallels / VMware — run Windows VM with MT5"
    echo -e "    ${CYAN}•${NC} Remote VPS — run MT5 on a Linux VPS, Noema on macOS"
    echo ""
    echo -e "  ${CYAN}→${NC} Noema's analytics, backtesting, and paper trading all work on macOS."
fi

# ── Step 2:
section "Step 2: Python environment"

# Pre-check: mt5linux Python package
if [ "$NEED_WINE" = "true" ]; then
    if python3 -c "import mt5linux" 2>/dev/null; then
        MT5LINUX_INSTALLED=true
        success "mt5linux Python package — already installed"
    else
        MT5LINUX_INSTALLED=false
        warn "mt5linux not installed — will install during venv setup"
    fi
fi

# Detect package manager
if command -v uv &> /dev/null; then
    PKG_MGR="uv"
    info "Using uv (fast Python package manager)"
    uv venv .venv 2>/dev/null || true
    activate_venv
    uv sync
    success "Python dependencies installed via uv"
else
    PKG_MGR="pip"
    info "Using pip"
    python3 -m venv .venv
    activate_venv
    pip install --upgrade pip
    # Install core deps + mt5linux (Linux only)
    pip install -e ".[dev]"
    [ "$NEED_WINE" = "true" ] && pip install mt5linux && success "mt5linux installed (Linux MT5 bridge)"
    success "Python dependencies installed via pip (incl. mt5linux for Linux MT5)"
fi

# ── Step 2.5: mt5linux EA Auto-Install ──────────────────────────
if [ "$NEED_WINE" = "true" ]; then
    section "Step 2.5: mt5linux Expert Advisor setup"
    info "Installing mt5linux bridge into MT5..."
    activate_venv
    MTL5_EA_DST="$HOME/.wine/drive_c/Program Files/MetaTrader 5/MQL5/Experts/mt5linux.ex5"
    MT5_EA_DST_X86="$HOME/.wine/drive_c/Program Files (x86)/MetaTrader 5/MQL5/Experts/mt5linux.ex5"
    if [ -f "$MTL5_EA_DST" ]; then
        success "mt5linux EA already installed"
    elif [ -f "$MT5_EA_DST_X86" ]; then
        success "mt5linux EA already installed (x86 path)"
    else
        mkdir -p "$(dirname "$MTL5_EA_DST")" 2>/dev/null || true
        info "Downloading mt5linux EA from GitHub (pip package does NOT include .ex5)..."
        wget -q -O "$MTL5_EA_DST" \
            https://github.com/lucas-campagna/mt5linux/releases/latest/download/mt5linux.ex5 2>/dev/null || \
        wget -q -O "$MTL5_EA_DST" \
