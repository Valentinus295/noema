# ────────────────────────────────────────────────────────────────
# Noema Docker Environment Configuration
# ────────────────────────────────────────────────────────────────
# Copy this file to the project root as `.env` and fill in values.
#   cp config/docker.env.example .env
#
# ALL values here are defaults for local development.
# Change passwords before deploying to production.
# ────────────────────────────────────────────────────────────────

# ── PostgreSQL ──────────────────────────────────────────────
POSTGRES_USER=noema
POSTGRES_PASSWORD=noema_dev
POSTGRES_DB=noema
POSTGRES_PORT=5432

# ── Redis ───────────────────────────────────────────────────
REDIS_PASSWORD=noema_redis_dev
REDIS_PORT=6379

# ── Prometheus ──────────────────────────────────────────────
PROMETHEUS_PORT=9090

# ── Grafana ─────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
GRAFANA_PORT=3000

# ── MetaTrader 5 ────────────────────────────────────────────
NOEMA_MT5_LOGIN=12345678
NOEMA_MT5_PASSWORD=your_mt5_password
NOEMA_MT5_SERVER=YourBroker-Live

# ── NVIDIA NIM (LLM API) ────────────────────────────────────
NIM_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxx
NIM_MODEL=meta/llama-3.1-70b-instruct

# ── Database URLs (used by Python app) ──────────────────────
# PostgreSQL async connection string
DATABASE_URL=postgresql+asyncpg://noema:noema_dev@postgres:5432/noema

# Redis connection string
REDIS_URL=redis://:noema_redis_dev@redis:6379/0

# DuckDB path (inside container or host-relative)
DUCKDB_PATH=data/noema.duckdb

# ── Trading Configuration ───────────────────────────────────
# Comma-separated list of pairs
TRADING_PAIRS=EURUSD,GBPUSD,USDJPY,AUDUSD,XAUUSD

# Cycle interval in seconds (how often the orchestrator loop runs)
CYCLE_INTERVAL=60

# Broker: "mt5", "paper", or "fbs" (see noema/broker/)
BROKER_BACKEND=paper

# ── Observability ───────────────────────────────────────────
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Prometheus metrics port for the Python app
METRICS_PORT=8000

# OpenTelemetry (optional — leave blank to disable)
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=noema

# ── Security ────────────────────────────────────────────────
# Secret key for session tokens, API auth, etc.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
NOEMA_SECRET_KEY=change-me-in-production

# Allowed origins for CORS (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
