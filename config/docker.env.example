# ────────────────────────────────────────────────────────────────
# Noema Docker Environment Configuration
# ────────────────────────────────────────────────────────────────
# Copy to project root as .env and fill in values.
# Run ./noema-setup to auto-generate secure passwords.
# ────────────────────────────────────────────────────────────────

# ── PostgreSQL ──────────────────────────────────────────────
POSTGRES_USER=noema
POSTGRES_PASSWORD=
POSTGRES_DB=noema
POSTGRES_PORT=5432

# ── Redis ───────────────────────────────────────────────────
REDIS_PASSWORD=
REDIS_PORT=6379

# ── Prometheus ──────────────────────────────────────────────
PROMETHEUS_PORT=9090

# ── Grafana ─────────────────────────────────────────────────
GRAFANA_PORT=3001
GRAFANA_PASSWORD=

# ── MT5 (for Docker-based live trading; optional) ───────────
Noema_MT5_LOGIN=
Noema_MT5_PASSWORD=
Noema_MT5_SERVER=

# ── NVIDIA NIM (for LLM agents) ─────────────────────────────
NIM_API_KEY=

# ── Langfuse (optional LLM observability) ───────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ── Otel (optional distributed tracing) ─────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=
