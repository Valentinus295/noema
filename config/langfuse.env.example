# ══════════════════════════════════════════════════════════════════════
# Noema — Langfuse Observability Configuration
# ══════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your credentials:
#   cp config/langfuse.env.example .env
#
# Langfuse provides LLM observability: traces, prompts, tokens, costs.
# Combine with OpenTelemetry for distributed tracing across all agents.
# ══════════════════════════════════════════════════════════════════════

# ── Langfuse ────────────────────────────────────────────────────
# Get your keys from https://cloud.langfuse.com → Settings → API Keys
LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxxxxxxxxxxxxx
LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxxxxxxxxxxxxx

# Langfuse host (change for self-hosted):
#   Cloud:    https://cloud.langfuse.com
#   Self-hosted: http://localhost:3000
LANGFUSE_HOST=https://cloud.langfuse.com

# Release tag (shown in Langfuse UI for filtering)
LANGFUSE_RELEASE=2.0.0

# ── OpenTelemetry (OTLP) ────────────────────────────────────────
# Option A: Export directly to Langfuse (they support OTLP ingestion)
#   OTEL_EXPORTER_OTLP_ENDPOINT=https://cloud.langfuse.com/api/public/otel
#   OTEL_EXPORTER_OTLP_HEADERS=Authorization=Bearer pk-lf-...:sk-lf-...
#
# Option B: Export to a local OTel Collector (Jaeger, Grafana Agent, etc.)
#   OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_EXPORTER_OTLP_ENDPOINT=

# OTel headers (optional — only needed for direct Langfuse export)
# Format: "key1=value1,key2=value2"
OTEL_EXPORTER_OTLP_HEADERS=

# Service name (identifies this deployment in traces)
OTEL_SERVICE_NAME=noema

# Deployment environment (development, staging, production)
OTEL_DEPLOYMENT_ENVIRONMENT=development

# ── Sampling ────────────────────────────────────────────────────
# What fraction of traces to sample (0.0 = none, 1.0 = all)
# In production with high throughput, sample 0.1-0.5
# In development, sample 1.0
OTEL_TRACES_SAMPLER=parentbased_always_on
OTEL_TRACES_SAMPLER_ARG=1.0

# ── Batch Processing ────────────────────────────────────────────
# Max spans per export batch
OTEL_BSP_MAX_EXPORT_BATCH_SIZE=512

# How often to export (milliseconds)
OTEL_BSP_SCHEDULE_DELAY=5000

# Max queue size before dropping spans
OTEL_BSP_MAX_QUEUE_SIZE=2048
