# --- LiteLLM proxy (already running on localhost:4000 per user CLAUDE.md) ---
LITELLM_BASE_URL=http://localhost:4000
LITELLM_MASTER_KEY=__set_me__
VMPM_LLM_MODEL=mistral-medium-3.5-128b

# --- MT5 (FxPesa terminal under Wine) ---
# mt5linux RPyC bridge defaults to port 18812
VMPM_BROKER=fxpesa
MT5_HOST=127.0.0.1
MT5_PORT=18812
MT5_LOGIN=00000000
MT5_PASSWORD=__set_me__
MT5_SERVER=FxPesa-Real    # or FxPesa-Demo
MT5_TERMINAL_PATH=/home/valentinetech/.wine/drive_c/Program Files/MetaTrader 5/terminal64.exe

# --- News / calendar ---
FINNHUB_API_KEY=__set_me__

# --- Telegram control surface ---
# Auth = TELEGRAM_CHAT_ID whitelist AND VMPM_TELEGRAM_SHARED_SECRET token
# required on every command (e.g. /flatten <secret>). See docs/SECURITY.md.
TELEGRAM_BOT_TOKEN=__set_me__
TELEGRAM_CHAT_ID=__set_me__
VMPM_TELEGRAM_SHARED_SECRET=__set_me__

# --- Mode ---
VMPM_MODE=paper            # paper | live
VMPM_LOG_LEVEL=INFO
