# Noema Environment Configuration
# Copy to .env and fill in your values
#
# ⚠️  CRITICAL: Default config is DEMO-ONLY.
#     Noema will BLOCK trading on any server name that doesn't contain "Demo".
#     This is a SAFETY FEATURE — never bypass casually.

# ── NVIDIA NIM ──────────────────────────────────────────────
# Get your API key from https://build.nvidia.com/
NIM_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxx

# ── MetaTrader 5 Broker ────────────────────────────────────
# ⚠️  MUST be a DEMO server for live trading to work!
#   FxPesa-Demo — ✅ Safe (demo account, no real money)
#   FxPesa-Live — ❌ BLOCKED (real money protection)
#   FBS-Demo    — ✅ Safe
#   FBS-Real    — ❌ BLOCKED
Noema_MT5_LOGIN=12345678
Noema_MT5_PASSWORD=your_mt5_password
Noema_MT5_SERVER=FxPesa-Demo

# Emergency override (DO NOT USE CASUALLY):
# Noema_ALLOW_LIVE_ACCOUNT=true

# Wine MT5 path (Pop!_OS / Ubuntu default)
# MT5_PATH=/home/$USER/.wine/drive_c/Program Files/MetaTrader 5/terminal64.exe

# ── Database ────────────────────────────────────────────────
# PostgreSQL (production) — leave blank to use SQLite fallback
DATABASE_URL=postgresql+asyncpg://noema:password@localhost:5432/noema

# Redis (caching + pub/sub) — leave blank to disable
REDIS_URL=redis://localhost:6379/0

# ── Trading ─────────────────────────────────────────────────
# Comma-separated list of pairs to trade
TRADING_PAIRS=EURUSD,GBPUSD,USDJPY,AUDUSD,XAUUSD

# Cycle interval in seconds (default: 60)
CYCLE_INTERVAL=60

# ── MT5 Headless Daemon ────────────────────────────────────
# Start MT5 automatically in the background (no window needed)
# Requires: xvfb (sudo apt install xvfb), Wine, MT5 installed
Noema_MT5_HEADLESS=true
Noema_MT5_STARTUP_WAIT=120

# ── Logging ─────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Broker Alerting ────────────────────────────────────────
# Send Telegram alerts when broker disconnects for > 15 seconds
# and when it reconnects. Requires Telegram bot configured.
Noema_ALERT_BROKER_DISCONNECT=true

# ── Position Sizing ────────────────────────────────────────
# Hard cap on lot size per order. Enforced BEFORE broker submission.
# Any order exceeding this is rejected with OrderRejectedError.
Noema_MAX_LOT_SIZE=1.0

# ── Actor Lifecycle ─────────────────────────────────────────
# Maximum consecutive rejections before the orchestrator pauses an
# actor (agent or symbol pipeline) for review.
Noema_ACTOR_MAX_REJECTIONS=50

# ── Learning Freeze ─────────────────────────────────────────
# If running drawdown exceeds this fraction (default 0.10 = 10%),
# the LearningAgent freezes — it stops updating knowledge from
# new trades until drawdown recovers below this threshold.
Noema_LEARNING_FREEZE_DRAWDOWN=0.10

# ── Phase 1.5: Economic Calendar & News Blackout ─────────────
# Total blackout window around high-impact events (minutes).
# Default 30 = 15 minutes before + 15 minutes after the event.
Noema_EVENT_BLACKOUT_MINUTES=30

# Interval between economic calendar polls (seconds).
# Default 300 = check every 5 minutes.
Noema_EVENT_POLL_INTERVAL_SECONDS=300

# Only blackout for high-impact (red) events. Set to "false" to
# also blackout on medium-impact events.
Noema_EVENT_HIGH_IMPACT_ONLY=true

# Hard timeout for any single blackout — prevents permanent freeze.
# After this limit (minutes), blackout is force-released and an
# alert is logged. COO condition #1.
Noema_EVENT_MAX_BLACKOUT_MINUTES=60

# Behavior when calendar API is unavailable.
# "conservative" = assume high-impact events → activate blackout
# "permissive"   = assume no events → proceed normally
# COO condition #2.
Noema_EVENT_CALENDAR_FAILURE_MODE=conservative

# Position size multiplier during medium-impact events or
# conservative failure mode. Default 0.50 = trade at 50% size.
Noema_EVENT_REDUCED_SIZE_PCT=0.50

# Minutes before an event to activate the blackout.
Noema_EVENT_LEAD_MINUTES=15

# Minutes after an event to deactivate the blackout
# (if volatility has normalized).
Noema_EVENT_TRAIL_MINUTES=15

# ── Dashboard ───────────────────────────────────────────────
# Comma-separated list of allowed CORS origins for the FastAPI
# dashboard backend. Default is localhost:3000 (dev React server).
Noema_CORS_ORIGIN=http://localhost:3000
