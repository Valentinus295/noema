# VMPM Environment Configuration
# Copy to .env and fill in your values

# ── NVIDIA NIM ──────────────────────────────────────────────
# Get your API key from https://build.nvidia.com/
NIM_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxx

# ── MetaTrader 5 ────────────────────────────────────────────
VMPM_MT5_LOGIN=12345678
VMPM_MT5_PASSWORD=your_mt5_password
VMPM_MT5_SERVER=YourBroker-Live

# ── Database ────────────────────────────────────────────────
# PostgreSQL (production) — leave blank to use SQLite fallback
DATABASE_URL=postgresql+asyncpg://vmpm:password@localhost:5432/vmpm

# Redis (caching + pub/sub) — leave blank to disable
REDIS_URL=redis://localhost:6379/0

# ── Trading ─────────────────────────────────────────────────
# Comma-separated list of pairs to trade
TRADING_PAIRS=EURUSD,GBPUSD,USDJPY,AUDUSD,XAUUSD

# Cycle interval in seconds (default: 60)
CYCLE_INTERVAL=60

# ── Logging ─────────────────────────────────────────────────
LOG_LEVEL=INFO
